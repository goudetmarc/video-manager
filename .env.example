# Chemin du dossier vidéo (NAS). Optionnel si vous passez ?path=... dans la page.
video_root=/Volumes/NAS/Videos

# =============================================================================
# Supabase Configuration (Optional)
# =============================================================================
# Pour utiliser Supabase comme stockage cloud au lieu des fichiers JSON locaux,
# configurez ces variables. Sans elles, l'app utilise le stockage local.
#
# 1. Créez un projet sur https://supabase.com
# 2. Exécutez le schéma SQL: supabase_schema.sql
# 3. Copiez l'URL et la clé (service role key) depuis les paramètres du projet

# URL du projet Supabase (ex: https://xxxxx.supabase.co)
SUPABASE_URL=

# Clé API Supabase (service_role key recommandée pour le backend)
# Trouvable dans: Project Settings > API > service_role key
SUPABASE_KEY=

# =============================================================================
# Radarr - Auto-téléchargement des films depuis la wishlist streaming
# =============================================================================
# URL Radarr (ex: http://localhost:7878)
RADARR_URL=http://localhost:7878

# Clé API Radarr (Settings > General > Security > API Key)
RADARR_API_KEY=

# =============================================================================
# Sonarr - Auto-téléchargement des séries depuis la wishlist streaming
# =============================================================================
# URL Sonarr (ex: http://localhost:8989)
SONARR_URL=http://localhost:8989

# Clé API Sonarr (Settings > General > Security > API Key)
SONARR_API_KEY=
